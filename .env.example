# Copy to .env in repo root or export before compose (compose reads .env from cwd)

POSTGRES_USER=pam
POSTGRES_PASSWORD=pam_dev_change_me
POSTGRES_DB=pam

# Used by backend container (host is service name `postgres` on Docker network)
DATABASE_URL=postgresql://pam:pam_dev_change_me@postgres:5432/pam

REDIS_URL=redis://redis:6379

# Logged in audit metadata for approve/deny (Phase 1 has no real admin auth)
PAM_ADMIN_USER=admin

BACKEND_PORT=3001
DASHBOARD_PORT=3000

# URL the browser uses to call the API (set at dashboard image build time)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Note: docker-compose does not publish Postgres or Redis ports on the host by default,
# so this stack can run alongside OS-level PostgreSQL/Redis (no :5432/:6379 bind conflicts).
