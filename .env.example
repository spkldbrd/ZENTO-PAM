# Copy to .env in repo root or export before compose (compose reads .env from cwd)

POSTGRES_USER=pam
POSTGRES_PASSWORD=pam_dev_change_me
POSTGRES_DB=pam

# Used by backend container (host is service name `postgres` on Docker network)
DATABASE_URL=postgresql://pam:pam_dev_change_me@postgres:5432/pam

REDIS_URL=redis://redis:6379

# Logged in audit metadata for approve/deny (Phase 1 has no real admin auth)
PAM_ADMIN_USER=admin

BACKEND_PORT=3001
DASHBOARD_PORT=3000

# Optional: explicit API URL for the browser (baked at dashboard **build** time).
# Leave unset or use localhost for local dev. For a **remote** technician opening
# http://YOUR_SERVER:3000, the dashboard now defaults the API to the same host on
# port 3001 (e.g. http://YOUR_SERVER:3001) so "failed to fetch" from localhost
# mismatch is avoided. Set this only if the API is on a different host/path than
# same-host:3001 (e.g. HTTPS reverse proxy).
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Note: docker-compose does not publish Postgres or Redis ports on the host by default,
# so this stack can run alongside OS-level PostgreSQL/Redis (no :5432/:6379 bind conflicts).
