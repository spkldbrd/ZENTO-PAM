{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true
  },
  "include": ["server.ts", "api/**/*.ts", "models/**/*.ts", "services/**/*.ts", "db/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
